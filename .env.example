# Telegram bot token from @BotFather
BOT_TOKEN=123456789:REPLACE_ME

# Public Vercel URL after deployment
PUBLIC_APP_URL=https://eralash-combat1.vercel.app

# Any long random string. Used by Telegram to sign webhook delivery.
TELEGRAM_WEBHOOK_SECRET=replace-with-long-random-string

# Optional: protects /api/set-webhook endpoint
SETUP_SECRET=replace-with-private-setup-code


# Supabase/Postgres persistent storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_secret_key
