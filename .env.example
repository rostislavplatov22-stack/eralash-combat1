# Telegram bot token from @BotFather
BOT_TOKEN=123456789:REPLACE_ME

# Public Vercel URL after deployment
PUBLIC_APP_URL=https://eralash-combat1.vercel.app

# Any long random string. Used by Telegram to sign webhook delivery.
TELEGRAM_WEBHOOK_SECRET=replace-with-long-random-string

# Optional: protects /api/set-webhook endpoint
SETUP_SECRET=replace-with-private-setup-code


# Supabase/Postgres persistent storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_secret_key

# Admin panel access
# Comma-separated Telegram user IDs allowed to open /api/admin from Mini App.
ADMIN_TELEGRAM_IDS=123456789

# Optional browser/testing secret for /api/admin?secret=...
# Keep it private. Can reuse SETUP_SECRET, but a separate value is cleaner.
ADMIN_API_SECRET=replace-with-private-admin-secret

# Optional: bot username without @ for referral deep links
BOT_USERNAME=eralash_combat_bot
